# client/.env.example
# Copy to client/.env for local dev
# In Netlify: set this under Site Settings → Environment Variables

# WebSocket URL pointing to your Render server
# Local dev:
VITE_WS_URL=ws://localhost:3001
# Production (after Render deploy):
# VITE_WS_URL=wss://iteach-calldash-server.onrender.com
